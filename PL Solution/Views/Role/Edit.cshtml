@model RoleViewModel
@{
    ViewData["Title"] = "Edit Role";
}

<style>
    body {
        background-color: #f4f7f6;
        font-family: 'Inter', sans-serif;
    }

    .custom-card {
        border-radius: 16px;
        border: none;
        background: #ffffff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #e0e0e0;
        transition: all 0.3s;
    }

        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
            border-color: #0d6efd;
        }

    .icon-box {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card custom-card">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-5">
                        <div class="icon-box me-3">
                            <i class="bi bi-shield-check fs-4"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Role Settings</h4>
                            <small class="text-muted">Modify access levels and role names</small>
                        </div>
                    </div>

                    <!-- ===================== -->
                    <!-- Form 1 : Edit Role   -->
                    <!-- ===================== -->
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-5">
                            <label asp-for="Name" class="form-label fw-bold text-muted">
                                Role Identity Name
                            </label>
                            <input asp-for="Name" class="form-control"
                                   placeholder="e.g. System Administrator" />
                            <span asp-validation-for="Name"
                                  class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 mb-3">
                            <button type="button"
                                    class="btn btn-outline-success"
                                    data-bs-toggle="modal"
                                    data-bs-target="#userPermissionsModal">
                                <i class="bi bi-people-fill me-2"></i>
                                Configure User Permissions
                            </button>
                        </div>

                        <div class="d-flex gap-3 pt-3">
                            <button type="submit"
                                    class="btn btn-primary flex-grow-1">
                                <i class="bi bi-check-circle-fill me-1"></i>
                                Save Changes
                            </button>

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>
                                Back To List
                            </a>
                        </div>
                    </form>
                    <!-- ===================== -->
                    <!-- End Form 1            -->
                    <!-- ===================== -->

                </div>
            </div>

        </div>
    </div>
</div>

<!-- ===================== -->
<!-- Modal (Form 2)       -->
<!-- ===================== -->
<div class="modal fade" id="userPermissionsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Add Users To @Model.Name Role
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">

                <form asp-action="AddOrRemoveUsers"
                      asp-route-roleId="@Model.Id"
                      method="post">

                    <partial name="PartialViews/_AddOrRemovePartialView"
                             model="Model.Users" />

                    <div class="modal-footer">
                        <button type="submit"
                                class="btn btn-success">
                            Add
                        </button>

                        <button type="button"
                                class="btn btn-light"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                    </div>

                </form>

            </div>

        </div>
    </div>
</div>
