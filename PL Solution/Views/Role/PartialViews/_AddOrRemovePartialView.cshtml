@model List<UserInRoleViewModel>

<div class="user-selection-list border rounded-3 p-2" style="max-height: 350px; overflow-y: auto; background-color: #fcfcfc;">
    @for (int i = 0; i < Model.Count; i++)
    {
        <div class="user-item d-flex align-items-center p-2 mb-1 rounded-3 transition-all" style="background: white; border-bottom: 1px solid #f0f0f0;">
            <div class="form-check d-flex align-items-center w-100">
                <input type="hidden" asp-for="@Model[i].UserId" />
                <input type="hidden" asp-for="@Model[i].UserName" />

                <input asp-for="@Model[i].IsSelected" class="form-check-input me-3 shadow-none" />
                <label class="form-check-label d-flex align-items-center cursor-pointer" asp-for="@Model[i].IsSelected">
                    <div class="avatar-sm me-2 bg-light text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 30px; height: 30px; font-size: 0.7rem;">
                        @Model[i].UserName.Substring(0, 1).ToUpper()
                    </div>
                    <span class="small fw-medium">@Model[i].UserName</span>
                </label>
            </div>
        </div>
    }
</div>