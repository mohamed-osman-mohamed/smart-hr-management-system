                @* <i class="bi bi-cpu-fill fs-5"></i> *@
                <img class="w-100" src="~/Files/images/NavIcon.png" alt="Alternate Text" />
            </div>
            <span class="tracking-tighter">SMART<span class="text-dark"> SYSTEM</span></span>
