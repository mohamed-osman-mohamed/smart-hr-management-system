                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employees" ? "active text-primary" : "")" asp-controller="Employees" asp-action="Index">Employees</a>
