                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active text-primary" : "")" asp-controller="Department" asp-action="Index">Departments</a>
                </li>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <li class="nav-item">
                        <a class="nav-link px-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Users" ? "active text-primary" : "")" asp-controller="Users" asp-action="Index">Users</a>
