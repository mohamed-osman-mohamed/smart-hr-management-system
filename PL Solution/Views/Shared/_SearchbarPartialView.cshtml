@model string

<div class="employee-search-wrapper mb-4">
    <div class="search-main-container">
        <form asp-action="Index" method="get" class="d-flex align-items-center w-100">
            <div class="search-input-group d-flex align-items-center flex-grow-1">
                <div class="search-icon-wrapper me-2">
                    <i class="bi bi-search" id="searchIcon"></i>
                    <div class="spinner-border spinner-border-sm text-primary d-none" id="searchLoader" role="status"></div>
                </div>
                <input id="SearchInput"
                       type="text"
                       name="EmployeeSearchName"
                       class="border-0 bg-transparent flex-grow-1 shadow-none"
                       style="outline: none; font-size: 1.05rem;"
                       placeholder="@(Model ?? "Search for ....")"
                       autocomplete="off">

                <button type="button" class="btn-clear d-none border-0 bg-transparent" id="clearSearch">
                    <i class="bi bi-x-lg text-muted"></i>
                </button>
            </div>

            <button type="submit" class="btn-search-submit ms-3">
                <i class="bi bi-filter-left me-1"></i>
                <span>Search</span>
            </button>
        </form>
    </div>
</div>