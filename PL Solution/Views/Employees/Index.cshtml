@model IEnumerable<EmployeeDto>

<div class="employee-table-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold-dark">Employee Directory</h3>
        <a class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px;"
           asp-controller="Employees" asp-action="Create">
            <i class="fa-solid fa-plus me-2"></i> Add New Employee
        </a>
    </div>

    <partial name="_SearchbarPartialView" model='"Search an employee..."' />

    <div id="TableWrapper" class="mt-4">
        <partial name="_TablePartialView" model="@Model" />
    </div>

    <div id="noDataAlert" class="text-center p-5 d-none bg-light rounded-3 mt-3">
        <i class="fa-solid fa-magnifying-glass fa-3x mb-3 text-muted" style="opacity: 0.3;"></i>
        <h5 class="text-secondary">No matching employees found!</h5>
    </div>
</div>