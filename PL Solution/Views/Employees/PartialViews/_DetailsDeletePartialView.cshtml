@model EmployeeDetailsDto


<!-- Details & Delete information Component -->
<!-- General Tab Content -->
<div class="tab-pane fade show active p-4 border" id="general" role="tabpanel" aria-labelledby="general-tab">
    <div class="row">
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Email"></label>
            <input asp-for="Email" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Address"></label>
            <input asp-for="Address" class="form-control" readonly
                   value="@($" {Model.Address?.Street} St - {Model.Address?.State} - {Model.Address?.City} - {Model.Address?.Country ?? null}")" />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="PhoneNumber"></label>
            <input asp-for="PhoneNumber" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Age"></label>
            <input asp-for="Age" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="HiringDate"></label>
            <input asp-for="HiringDate" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Salary"></label>
            <input asp-for="Salary" asp-format="{0:C}" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="Gender"></label>
            <input asp-for="Gender" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="EmployeeType"></label>
            <input asp-for="EmployeeType" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            <label class="form-label" asp-for="DepartmentName"></label>
            <input asp-for="DepartmentName" class="form-control" readonly />
        </div>
        <div class="form-group mb-3 col-6">
            @if (Model.IsActive)
            {
                <i class="fa-solid fa-circle-check text-success"></i>
                <label class="col-form-label" asp-for="IsActive">Is Active</label>
            }
            else

            {
                <i class="fa-solid fa-circle-xmark text-danger"></i>
                <label class="col-form-label" asp-for="IsActive">Not Active</label>
            }
        </div>
    </div>
</div>

<!-- Administration Tab Content -->
<div class="tab-pane fade p-4 border" id="administration" role="tabpanel" aria-labelledby="administration-tab">
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="CreatedBy"></label>
        <input asp-for="CreatedBy" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="CreatedOn"></label>
        <input asp-for="CreatedOn" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="LastModifiedBy"></label>
        <input asp-for="LastModifiedBy" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="LastModifiedOn"></label>
        <input asp-for="LastModifiedOn" class="form-control" readonly />
    </div>
</div>

<!-- Confirm massage-->
<div class="modal fade" id="DeleteModal-@Model.Id" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Employee</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are You Sure to Delete this Employee?
            </div>
            <div class="modal-footer">
                <form asp-action="Delete" asp-controller="Employees" asp-route-id="@Model.Id" class="mt-4">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <input type="submit" value="Delete" class="btn btn-danger" />
                </form>
            </div>
        </div>
    </div>
</div>