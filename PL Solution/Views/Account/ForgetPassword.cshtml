@model ForgetPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .auth-card {
        width: 420px;
        padding: 40px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .auth-title {
        font-weight: 600;
        margin-bottom: 10px;
        color: #fff;
    }

    .auth-subtitle {
        font-size: 14px;
        color: rgba(255,255,255,0.8);
        margin-bottom: 25px;
    }

    .form-control {
        height: 45px;
        border-radius: 10px;
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
    }

        .form-control::placeholder {
            color: rgba(255,255,255,0.7);
        }

        .form-control:focus {
            background: rgba(255,255,255,0.3);
            color: #fff;
            box-shadow: none;
        }

    .btn-primary {
        height: 45px;
        border-radius: 10px;
        font-weight: 500;
    }

    .back-link {
        font-size: 14px;
        text-decoration: none;
        color: rgba(255,255,255,0.8);
    }

        .back-link:hover {
            color: #fff;
        }
</style>

<div class="auth-container">
    <div class="auth-card">

        <h3 class="auth-title">Forgot Password?</h3>
        <p class="auth-subtitle">
            Enter your email and we'll send you a reset link.
        </p>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form asp-action="SendResetPasswordLink" method="post">

            <div class="mb-3">
                <input asp-for="Email"
                       class="form-control"
                       placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-warning"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Send Reset Link
            </button>

        </form>

        <div class="text-center mt-4">
            <a asp-action="LogIn" class="back-link">
                ← Back to Login
            </a>
        </div>

    </div>
</div>

