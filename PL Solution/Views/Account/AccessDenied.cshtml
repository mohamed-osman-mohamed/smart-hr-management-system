@{
    Layout = "";
}

<!DOCTYPE html>
<html>
<head>
    <title>Access Denied</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta charset="UTF-8">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        .access-denied-container {
            min-height: 80vh;
            background: #f8f9fa;
        }

        /* أنيميشن خفيفة للأيقونة */
        .animate-bounce {
            animation: bounce 2s infinite;
        }

        @@keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateY(0);
            }

            40% {
                transform: translateY(-20px);
            }

            60% {
                transform: translateY(-10px);
            }
        }

        .bg-light-warning {
            background-color: #fff3cd;
            color: #856404;
            border-radius: 12px;
        }
    </style>

</head>
<body>

    <div class="access-denied-container d-flex align-items-center justify-content-center">
        <div class="text-center p-5 shadow-lg rounded-4 bg-white">
            <div class="lock-icon mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" fill="currentColor" class="bi bi-shield-lock-fill text-danger animate-bounce" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.8 11.8 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.8 11.8 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915V9a.5.5 0 0 1-1 0V7.915A1.5 1.5 0 0 1 8 5" />
                </svg>
            </div>

            <h1 class="display-4 fw-bold text-dark"> 🛑 stop right there! </h1>
            <p class="lead text-secondary mb-4">
                You Don't Have Permission To Access This Page.
            </p>

            <div class="alert alert-warning border-0 bg-light-warning py-3">
                <strong>Hint:</strong> If you think this is a mistake, try contacting the admin or make sure you are logged in with the Admin account.
            </div>

            <div class="mt-4 d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3 rounded-pill shadow-sm">
                Go Back
                </a>
            </div>
        </div>
    </div>

</body>
</html>