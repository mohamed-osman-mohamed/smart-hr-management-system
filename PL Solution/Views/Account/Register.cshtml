@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}
<div class="login-card-container animate-slide-up">
    <div class="row g-0 h-100">
        <div class="col-lg-6 d-flex align-items-center justify-content-center p-4 p-md-5">
            <div class="w-100" style="max-width: 350px;">
                <div class="text-center mb-2">
                    <p class="fw-bold fs-3  display-4 text-primary-dark">Create New Account</p>

                    <p class="text-muted"> quick & easy </p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small text-center mb-2"></div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <div class="input-group custom-input-group">
                                <input type="text" asp-for="FirstName" class="form-control" placeholder="First Name">
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <div class="input-group custom-input-group">
                                <input type="text" asp-for="LastName" class="form-control" placeholder="Last Name">
                            </div>
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="input-group custom-input-group">
                            <input type="text" asp-for="UserName" class="form-control" placeholder="User name">
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <div class="input-group custom-input-group">
                            <input type="email" asp-for="Email" class="form-control" placeholder="Email address">
                            <span class="input-group-text bg-transparent border-start-0 text-muted">
                                <i class="bi bi-envelope"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="input-group custom-input-group">
                            <input type="password" id="passInput" asp-for="Password" class="form-control" placeholder="Password">
                            <span class="input-group-text bg-transparent border-start-0 text-muted cursor-pointer" id="togglePass">
                                <i class="bi bi-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <div class="input-group custom-input-group">
                            <input type="password" id="passInput" asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password">
                            <span class="input-group-text bg-transparent border-start-0 text-muted cursor-pointer" id="togglePass">
                                <i class="bi bi-eye"></i>
                            </span>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 small">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" asp-for="IsAgree" id="rem">
                            <label class="form-check-label text-muted" for="rem">I Agree to tirms & conditions.</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-dark w-100 py-2 mb-3">Sign Up</button>

                    <div class="text-center mt-1">
                        <p class="small text-muted mb-0">Alredy have an account?</p>
                        <a asp-action="LogIn" class="text-primary-dark  text-decoration-none small"> Sign IN </a>
                    </div>
                    
                </form>
            </div>
        </div>

        <div class="col-lg-6 d-none d-lg-block p-3">
            <div class="Register-visual-box h-100 w-100"></div>
        </div>
    </div>
</div>