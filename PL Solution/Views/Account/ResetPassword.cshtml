@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .auth-card {
        width: 450px;
        padding: 45px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .auth-title {
        text-align: center;
        color: #fff;
        margin-bottom: 25px;
        font-weight: 600;
    }

    .form-control {
        height: 45px;
        border-radius: 10px;
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
    }

        .form-control::placeholder {
            color: rgba(255,255,255,0.7);
        }

        .form-control:focus {
            background: rgba(255,255,255,0.3);
            color: #fff;
            box-shadow: none;
        }

    .input-group-text {
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        cursor: pointer;
        color: #fff;
    }

    .btn-primary {
        height: 45px;
        border-radius: 10px;
        font-weight: 500;
    }
</style>

<div class="auth-container">
    <div class="auth-card">

        <h3 class="auth-title">Reset Your Password</h3>

        <form asp-action="ResetPassword" method="post">

            <div asp-validation-summary="ModelOnly" class="text-warning mb-3"></div>

            <!-- Password -->
            <div class="mb-3 input-group">
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="New Password"
                       id="password" />
                <span class="input-group-text" onclick="togglePassword('password')">👁</span>
            </div>
            <span asp-validation-for="Password" class="text-warning"></span>

            <!-- Confirm Password -->
            <div class="mb-3 input-group mt-3">
                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control"
                       placeholder="Confirm New Password"
                       id="confirmPassword" />
                <span class="input-group-text" onclick="togglePassword('confirmPassword')">👁</span>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-warning"></span>

            <button type="submit" class="btn btn-primary w-100 mt-4">
                Reset Password
            </button>

        </form>

    </div>
</div>

    <script>
        function togglePassword(id) {
            var input = document.getElementById(id);
            input.type = input.type === "password" ? "text" : "password";
        }
    </script>
}
