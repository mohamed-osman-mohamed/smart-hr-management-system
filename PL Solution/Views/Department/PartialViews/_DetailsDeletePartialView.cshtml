@model DepartmentDetailsDto
<!-- Details & Delete information Component -->
<!-- General Tab Content -->
<div class="tab-pane fade show active p-4 border" id="general" role="tabpanel" aria-labelledby="general-tab">

    <div class="row">
        <div class="form-group col-6">
            <label class="col-form-label" asp-for="Code"></label>
            <input asp-for="Code" class="form-control" readonly />
        </div>
        <div class="form-group col-6">
            <label class="col-form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" readonly />
        </div>
        <div class="form-group col-12">
            <label class="col-form-label" asp-for="Description"></label>
            <input asp-for="Description" class="form-control" readonly />
        </div>
        <div class="form-group col-12">
            <label class="col-form-label" asp-for="DateOfCreation"></label>
            <input asp-for="DateOfCreation" class="form-control" readonly />
        </div>

    </div>
</div>

<!-- Administration Tab Content -->
<div class="tab-pane fade p-4 border" id="administration" role="tabpanel" aria-labelledby="administration-tab">
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="CreatedBy"></label>
        <input asp-for="CreatedBy" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label">CreatedOn</label>
        <input asp-for="DateOfCreation" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="LastModifiedBy"></label>
        <input asp-for="LastModifiedBy" class="form-control" readonly />
    </div>
    <div class="form-group  col-12">
        <label class="col-form-label" asp-for="LastModifiedOn"></label>
        <input asp-for="LastModifiedOn" class="form-control" readonly />
    </div>
</div>

<!-- Confirm massage-->


<div class="modal fade" id="DeleteModal-@Model.Id" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">Delete Department</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are You Sure to Delete this Department?
            </div>
            <div class="modal-footer">
                <form asp-action="Delete" asp-controller="Department" asp-route-id="@Model.Id" class="mt-4">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <input type="submit" value="Delete" class="btn btn-danger" />
                </form>
            </div>
        </div>
    </div>
</div>