@model IEnumerable<DepartmentDto>
@{
    ViewData["Title"] = "Departments";
}

<partial name="_ToastPartialView" />

<div class="employee-table-container mt-5 ">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0" style="color: #2b3674;">Departments Directory</h4>
            <small class="text-muted">Organization structure and units</small>
        </div>
        <a class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px;"
           asp-controller="Department" asp-action="Create">
            <i class="fa-solid fa-plus me-2"></i> Create Department
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table id="DepartmentsTable" class="table innovative-table mt-3 text-center">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(d => d.Code)</th>
                        <th>@Html.DisplayNameFor(d => d.Name)</th>
                        <th>@Html.DisplayNameFor(d => d.Description)</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="DepartmentsTableBody">
                    @foreach (var department in Model)
                    {
                        <tr>
                            <td class="fw-bold" style="color: #4318ff;">
                                <code>@department.Code</code>
                            </td>
                            <td class="fw-bold" style="color: #2b3674;">@department.Name</td>
                            <td class="text-muted">
                                @(department.Description.Length > 50 ? department.Description.Substring(0, 50) + "..." : department.Description)
                            </td>
                            <td>
                                <span class="text-muted-small">
                                    <i class="fa-regular fa-calendar me-1"></i>
                                    @department.DateOfCreation.ToShortDateString()
                                </span>
                            </td>
                            <td>
                                <partial name="_ButtonsPartialView" model="department.Id.ToString()" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center p-5 bg-light rounded-3 mt-3">
            <i class="fa-solid fa-layer-group fa-3x mb-3 text-muted" style="opacity: 0.3;"></i>
            <h5 class="text-secondary">No Departments Found !!</h5>
            <p class="text-muted">You haven't added any departments to the system yet.</p>
        </div>
    }
</div>